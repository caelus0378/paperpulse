# ============================================================
# PaperPulse — 环境变量配置模板
# 复制此文件为 .env 并填入你的实际值
#   cp .env.example .env
# ============================================================

# DeepSeek API Key（必填）
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API 地址（可选，默认即官方地址）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型名称（可选）
DEEPSEEK_MODEL=deepseek-chat

# arXiv 请求间隔秒数（可选，默认 5 秒，越小越容易 429）
ARXIV_DELAY=5.0

# 定时任务每日执行时间（可选，默认早上 8:00）
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Web UI 配置（可选）
WEB_HOST=0.0.0.0
WEB_PORT=7860

# 日志级别（可选）
LOG_LEVEL=INFO
